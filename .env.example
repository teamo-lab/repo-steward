# Edward configuration — all variables optional.
#
# Edward has zero required config. It stores state in-memory and
# invokes the `claude` CLI as a subprocess for analysis.

# Port the dashboard/API server binds to. Default: 8080.
# Overridden by `edward serve --port N`.
# EDWARD_PORT=8080

# URL the CLI subcommands talk to. Default: http://localhost:8080.
# Overridden by `--url` on any command.
# EDWARD_URL=http://localhost:8080

# Path to the `claude` CLI binary used for agent analysis.
# By default Edward auto-detects via `command -v claude` on your PATH
# and falls back to common install locations (/opt/homebrew/bin,
# /usr/local/bin, ~/.local/bin, ~/.bun/bin, ~/.npm-global/bin).
# Set this only if your binary lives somewhere unusual.
# CLAUDE_BIN=/usr/local/bin/claude

# If set, the `claude` subprocess bills analysis runs to that API
# account and IGNORES any OAuth login you configured. Edward warns
# about this on `edward serve` startup and asks you to confirm
# interactively; pass --yes to skip the prompt. To use your OAuth
# login instead, `unset ANTHROPIC_API_KEY` before launching edward.
# ANTHROPIC_API_KEY=sk-ant-api03-...

# GitHub API token for repo verification and private repo access.
# Auto-detected from `gh auth token` if not set and `gh` is logged in.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Path to the seed file used by `edward serve` to re-add tracked repos
# at startup. Default: $HOME/.edward/seed.json (not auto-created).
# Format: {"repos": ["owner/name", ...]}
# Missing file is silently ignored. Bad entries log a warning and skip.
# EDWARD_SEED_FILE=/Users/me/.edward/seed.json
