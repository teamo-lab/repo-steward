# Repo Steward Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/repo_steward

# Redis
REDIS_URL=redis://localhost:6379

# GitHub App
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Anthropic (Claude API)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Steward Settings
MAX_DAILY_SUGGESTIONS=3
CONFIDENCE_THRESHOLD=0.75
DISCOVERY_CRON=0 6 * * *
EXECUTION_TIMEOUT=600000

# Notifications (optional)
SLACK_WEBHOOK_URL=
EMAIL_FROM=steward@repo-steward.dev
SMTP_URL=

# Logging
LOG_LEVEL=info
